{
  "$schema": "https://ui.shadcn.com/schema.json",
  "style": "radix-nova",
  "rsc": true,
  "tsx": true,
  "tailwind": {
    "config": "",
    "css": "src/styles/globals.css",
    "baseColor": "zinc",
    "cssVariables": true,
    "prefix": ""
  },
  "iconLibrary": "remixicon",
  "rtl": false,
  "menuColor": "default",
  "menuAccent": "subtle",
  "aliases": {
    "components": "@repo/ui-core/components",
    "utils": "@repo/ui-core/lib/utils",
    "hooks": "@repo/ui-core/hooks",
    "lib": "@repo/ui-core/lib",
    "ui": "@repo/ui-core/components"
  },
  "registries": {
    "@reui": "https://reui.io/r/{style}/{name}.json",
    "@elevenlabs-ui": "https://ui.elevenlabs.io/r/{name}.json"
  }
}
