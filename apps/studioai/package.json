{
  "name": "studioai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
    "check-types": "next typegen && tsc --noEmit",
    "db:migrate": "npx supabase@latest db push",
    "db:migrate:debug": "npx supabase@latest db push --debug",
    "deploy:function": "npx supabase@latest functions deploy --use-api --project-ref jhfmleapvwqvohtilpap",
    "deploy:functions:all": "for dir in supabase/functions/*; do if [ -d \"$dir\" ]; then name=$(basename \"$dir\"); echo \"Deploying function: $name\"; npx supabase@latest functions deploy \"$name\" --use-api --project-ref jhfmleapvwqvohtilpap; fi; done",
    "db:gen:types": "npx supabase@latest gen types typescript --project-id \"jhfmleapvwqvohtilpap\" --schema public > src/types/supabase.ts"
  },
